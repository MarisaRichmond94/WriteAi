# ============================================================================
# series-rag configuration
#
# Copy this file to `.env` and edit, or run `python settings.py` for a guided
# interactive setup. Every key is documented here; keys marked (optional) can
# be left blank.
# ============================================================================

# ── Paths ──────────────────────────────────────────────────────────────────

# Root directory containing one folder per book. ~ is expanded.
# The system NEVER writes anything under this directory.
BOOKS_DIR=~/Writing

# Display name of the series; also used (slugified) as the ChromaDB
# collection name.
SERIES_NAME=My Series

# Regex used to recognize which folders under BOOKS_DIR are books.
# Default matches "1. Nobody's Hero", "12. The Final Chapter", etc.
# Books are ordered by their numeric prefix, not alphabetically.
BOOK_PREFIX_PATTERN=^\d+\.

# Where all generated data lives: ChromaDB, SQLite, staging copies,
# extracted-text cache, chunk hashes. Relative paths are resolved against
# the repo root.
DATA_DIR=./data

# (optional) Directory of pre-exported plain-text versions of the books.
# If a .txt here matches a book's filename and is at least as new as the
# book's source file, it is used directly instead of converting the source.
# Useful when an existing pipeline already exports the manuscripts nightly.
# Leave blank to always convert from the source files.
TEXT_EXPORT_DIR=

# ── Models ─────────────────────────────────────────────────────────────────

# Used for metadata extraction during ingestion (optimize for cost).
EXTRACTION_MODEL=claude-haiku-4-5

# Used for answering questions (optimize for quality).
QUERY_MODEL=claude-sonnet-4-6

# Used ONLY for the relationship-nature enrichment pass ("who is X to Y").
# Direction inference is where the small extraction model demonstrably fails;
# leave blank to fall back to EXTRACTION_MODEL.
ENRICH_REL_MODEL=

# ── Embeddings ─────────────────────────────────────────────────────────────

# 'local'  -> sentence-transformers, runs on this machine, no API cost
# 'openai' -> text-embedding-3-small (requires OPENAI_API_KEY)
EMBEDDING_PROVIDER=local

# (optional) Which sentence-transformers model to use when
# EMBEDDING_PROVIDER=local. Defaults to nomic-ai/nomic-embed-text-v1.
EMBEDDING_MODEL=

# ── API keys ───────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=
# (optional) Only required if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# ── Ingestion behavior ─────────────────────────────────────────────────────

# Maximum size of a chunk, in (estimated) tokens. Scenes larger than this
# are split at paragraph boundaries.
MAX_CHUNK_TOKENS=800

# How many chunks to retrieve per query by default.
TOP_K_RESULTS=15

# When true, every ingestion run shows a cost estimate and waits for an
# explicit 'yes' before making any API calls (ingest.py --yes skips this,
# for cron).
CONFIRM_BEFORE_INGEST=true

# ── Retrieval features ─────────────────────────────────────────────────────

# When true, semantic search is fused with SQLite FTS5 (BM25) keyword search
# via Reciprocal Rank Fusion — helps exact-name/rare-term lookups. When
# false (the default), retrieval is pure vector search.
ENABLE_HYBRID_SEARCH=false

# When true, character names found in a question are expanded to their
# grounded alias sets (via the same canonicalizer the review UI uses) before
# the SQL-backed retrieval paths run — so "Cat" also matches rows tagged
# "Cat Kissinger", and "Bri" matches "Brielle Draper". Only affects the
# structured (SQLite) lookups; semantic (embedding) search is untouched.
ENABLE_ALIAS_RESOLUTION=false

# When true, the semantic retrieval path over-fetches a deeper candidate
# pool and rescores it with a local cross-encoder before the final top-K
# cut. Cross-encoders read the (question, excerpt) pair jointly, so they
# rank relevance much better than raw vector distance — at the cost of a
# little query latency. Runs fully locally (no API cost); the model (~90MB)
# downloads to the Hugging Face cache on first use.
ENABLE_RERANKER=false

# (optional) Which cross-encoder model to rerank with. Blank means the
# default, cross-encoder/ms-marco-MiniLM-L-6-v2.
RERANKER_MODEL=

# How many candidates to over-fetch for reranking. The effective pool is
# max(RERANK_CANDIDATES, 2 * TOP_K_RESULTS). 80 is the eval-tuned default
# (only config where sentiment beats baseline); 40 halves rerank latency
# (~1s vs ~2s CPU) at slightly lower recall. Only used when
# ENABLE_RERANKER=true.
RERANK_CANDIDATES=80

# When true, metadata extraction is submitted through the Anthropic Message
# Batches API, which bills tokens at 50% of standard prices. Results can take
# up to an hour (usually much less), so this suits full re-ingests rather
# than quick incremental syncs. `ingest.py --batches` turns this on for a
# single run regardless of the value here.
EXTRACTION_USE_BATCHES=false

# When true, multi-turn Explore chat marks the last prior turn as an
# Anthropic prompt-cache breakpoint, so turn N+1 re-reads the whole prefix
# (system prompt + story bibles + earlier turns) at ~0.1x input price
# instead of re-paying full price. Changes cache metadata only — never the
# prompt text. One-shot CLI queries are unaffected (their cacheable prefix
# is far below the model minimum; see eval/CACHE_NOTES.md).
ENABLE_PROMPT_CACHE_V2=false

# When true (and CONTINUITY_NOTES_CAP > 0), continuity questions rank the
# foreshadowing / unresolved-question notes semantically instead of injecting
# every note in scope: the question is embedded and only the top
# CONTINUITY_NOTES_CAP most relevant notes are kept (re-sorted into
# chronological order, same line format). Requires the companion notes
# vector collection — build it once with:
#     .venv/bin/python scripts/backfill_note_embeddings.py
# (incremental ingests keep it in sync while this flag is on). If the
# collection is empty, retrieval logs a warning and falls back to the
# unranked behavior.
ENABLE_NOTE_RANKING=false

# Maximum number of continuity notes injected into the prompt when
# ENABLE_NOTE_RANKING is on. 0 = unlimited (the legacy behavior: every
# foreshadowing/unresolved note in scope, ~60K tokens on whole-series
# questions). Suggested when enabling: 300.
CONTINUITY_NOTES_CAP=0

# When true, sentiment questions that name characters build their excerpt
# candidate pool structurally (SQLite): chunks where the named characters
# co-occur and/or an extracted emotional beat ties them together, unioned
# with the semantic hits. When ENABLE_RERANKER is also true, the pool is
# rescored by the cross-encoder at the emotional-beat level (a chunk ranks
# as its best-matching beat); with the reranker off, structural candidates
# come first in chronological order. Fixes the eval-proven failure mode
# where the right scene sits far beyond semantic-search range.
ENABLE_SENTIMENT_V2=false

# When true, the answer model is instructed to support its claims with short
# VERBATIM quotes from the retrieved manuscript excerpts (exact words in
# double quotation marks, immediately followed by the (Book N, Chapter M)
# citation). Story notes are paraphrases, so claims backed only by a note are
# cited without quotation marks — the model never fabricates quotes from
# notes or from memory. Applies to every answer surface (CLI, chat, review).
# The instruction is appended to the system prompt in a stable position, so
# prompt caching (ENABLE_PROMPT_CACHE_V2) is unaffected.
ENABLE_DIRECT_QUOTES=false

# When true, "when/where does X first learn/hear/see ... about Y" questions
# get dedicated first-occurrence retrieval: the earliest character_knowledge
# ledger rows where X learns about Y (chronological, under a distinct notes
# header) plus the earliest prose chunks mentioning Y with X on the page
# (X's own POV preferred), prepended before the usual semantic hits. The
# answer model is instructed that these are drawn chronologically from an
# exhaustive index — so the earliest entry IS the first occurrence — and to
# distinguish first EXPOSURE from first UNDERSTANDING. Fixes the eval-proven
# failure where semantic top-K cannot establish firstness for a topic that
# appears in prose across dozens of chapters, mostly in other POVs.
ENABLE_FIRST_OCCURRENCE=false

# When true, the timeline can serve events in STORY-chronological order
# (GET /api/events?order=story) using the chapter_timeline table populated by
# scripts/resolve_chronology.py (a relative story_year per chapter from one
# cheap LLM call per book, plus month/day parsed from chapter date lines),
# and the UI shows a Narrative/Story order toggle. The default order stays
# narrative (book, chapter, position) either way; with the flag off the API
# and UI are identical to today.
ENABLE_STORY_ORDER=false

# When true, the location gazetteer is resolved per BOOK instead of once for
# the whole series (location_map_v2, populated by scripts/resolve_locations.py
# or automatically at the end of an enrichment run). Fixes cross-book venue
# collisions (a character who moves between books no longer collapses two
# homes into one), adds a third hierarchy level (region above settlement),
# keeps the sub-venue area ("bedroom") instead of discarding it, and lets
# anchored generic references ("the town") backfill to the canonical place
# once the series establishes it. The Locations pane and event location
# labels read the v2 map; with the flag off they are identical to today.
ENABLE_LOCATION_V2=false

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# When true, every API request appends one JSON line (tokens, cost, latency,
# active feature flags) to logs/cost.jsonl so spend is auditable over time.
# Purely observability — never changes any answer.
COST_LOG_ENABLED=true
